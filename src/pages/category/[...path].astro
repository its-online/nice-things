---
import bookmarks from "../../data/bookmarks.json";
import { getAllCategoryPaths } from "../../lib/bookmarks/routes";
import "../../styles/shared.css";

export function getStaticPaths() {
  const categoryPaths = getAllCategoryPaths(bookmarks);
  return categoryPaths.map((path) => {
    const pathString = path.join("/");
    return {
      params: { path: pathString },
      props: {
        path,
        pathString,
        bookmarks: bookmarks.filter(
          (b) => b.categoryPath.join("/") === pathString
        ),
      },
    };
  });
}

const { path, pathString, bookmarks: categoryBookmarks } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Category: {pathString} | Nice Things</title>
  </head>
  <body>
    <main>
      <a href="/" class="back-link">← Nice Things</a>

      <h1 class="page-title">
        <nav class="category-breadcrumb">
          {path.map((segment, i) => (
            <>
              {i > 0 && <span class="separator"> / </span>}
              <a href={`/category/${path.slice(0, i + 1).join("/")}`}>
                {segment}
              </a>
            </>
          ))}
        </nav>
      </h1>

      <ul class="bookmark-list">
        {categoryBookmarks.map((bookmark) => (
          <li class="bookmark-item">
            <a href={`/b/${bookmark.slug}`} class="bookmark-title">{bookmark.title}</a>
            <a href={bookmark.url} class="bookmark-url" target="_blank" rel="noopener noreferrer">
              {bookmark.url}
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>

<style>
  .bookmark-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bookmark-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .bookmark-item:last-child {
    border-bottom: none;
  }

  .bookmark-title {
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .bookmark-title:hover {
    text-decoration: underline;
  }

  .bookmark-url {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    word-break: break-all;
    text-decoration: none;
  }

  .bookmark-url:hover {
    text-decoration: underline;
  }

  .category-breadcrumb {
    font-size: 1rem;
  }

  .category-breadcrumb a {
    text-decoration: none;
  }

  .category-breadcrumb a:hover {
    text-decoration: underline;
  }
</style>
